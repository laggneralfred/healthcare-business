<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_appointment_form_encounter" model="ir.ui.view">
        <field name="name">hc.appointment.form.encounter</field>
        <field name="model">hc.appointment</field>
        <field name="inherit_id" ref="hc_scheduling.view_hc_appointment_form"/>
        <field name="priority">40</field>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="before">
                <header>
                    <button
                        name="action_open_encounter"
                        string="Open Encounter"
                        type="object"
                        class="btn-primary"
                        groups="hc_practice_core.hc_group_owner,hc_practice_core.hc_group_front_desk,hc_practice_core.hc_group_provider"
                    />
                </header>
            </xpath>
        </field>
    </record>
</odoo>
