<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_appointment_list" model="ir.ui.view">
        <field name="name">hc.appointment.list</field>
        <field name="model">hc.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="patient_id" string="Patient"/>
                <field name="start_datetime" string="Start"/>
                <field name="end_datetime" string="End"/>
                <field name="practitioner_id" string="Practitioner"/>
                <field name="appointment_type_id" string="Visit Type"/>
            </list>
        </field>
    </record>

    <record id="view_hc_appointment_form" model="ir.ui.view">
        <field name="name">hc.appointment.form</field>
        <field name="model">hc.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button
                        name="action_start_visit"
                        string="Start Visit"
                        type="object"
                        class="btn-primary"
                    />
                    <button
                        name="action_complete_visit"
                        string="Complete Visit"
                        type="object"
                        class="btn-secondary"
                    />
                    <button
                        name="action_close_visit"
                        string="Close Visit"
                        type="object"
                        class="btn-secondary"
                    />
                    <button
                        name="action_mark_needs_follow_up"
                        string="Mark Needs Follow-Up"
                        type="object"
                        class="btn-secondary"
                    />
                    <button
                        name="action_clear_follow_up"
                        string="Clear Follow-Up"
                        type="object"
                        class="btn-secondary"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label oe_edit_only">Appointment</span>
                        <h1>
                            <field name="patient_id" placeholder="Select Patient"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Schedule">
                            <field name="practice_id" string="Practice"/>
                            <field name="appointment_type_id" string="Visit Type"/>
                            <field
                                name="practitioner_id"
                                string="Practitioner"
                                domain="[('practice_id', '=', practice_id)]"
                            />
                            <field name="visit_status"/>
                            <field name="needs_follow_up"/>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                        <group string="Notes">
                            <field name="notes" string="Scheduling Notes" placeholder="Scheduling notes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hc_appointment_calendar" model="ir.ui.view">
        <field name="name">hc.appointment.calendar</field>
        <field name="model">hc.appointment</field>
        <field name="arch" type="xml">
            <calendar
                string="Appointments"
                date_start="start_datetime"
                date_stop="end_datetime"
                color="practitioner_id"
                mode="week"
                quick_create="false"
                event_open_popup="false"
            >
                <field name="name" string="Appointment"/>
                <field name="patient_id"/>
                <field name="appointment_type_id" string="Visit Type"/>
                <field name="practitioner_id" string="Practitioner"/>
            </calendar>
        </field>
    </record>

    <record id="action_hc_appointments" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hc.appointment</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="help" type="html">
            <p>Use Appointments to manage the clinic schedule for Sprint 1.</p>
        </field>
    </record>

    <record id="action_hc_appointments_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hc_scheduling.view_hc_appointment_list"/>
        <field name="act_window_id" ref="hc_scheduling.action_hc_appointments"/>
    </record>

    <record id="action_hc_appointments_calendar_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">calendar</field>
        <field name="view_id" ref="hc_scheduling.view_hc_appointment_calendar"/>
        <field name="act_window_id" ref="hc_scheduling.action_hc_appointments"/>
    </record>

    <record id="action_hc_appointments_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hc_scheduling.view_hc_appointment_form"/>
        <field name="act_window_id" ref="hc_scheduling.action_hc_appointments"/>
    </record>
</odoo>
