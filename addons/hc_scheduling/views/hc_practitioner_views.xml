<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_practitioner_list" model="ir.ui.view">
        <field name="name">hc.practitioner.list</field>
        <field name="model">hc.practitioner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="practice_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hc_practitioner_form" model="ir.ui.view">
        <field name="name">hc.practitioner.form</field>
        <field name="model">hc.practitioner</field>
        <field name="arch" type="xml">
            <form string="Practitioner">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="practice_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hc_practitioners" model="ir.actions.act_window">
        <field name="name">Practitioners</field>
        <field name="res_model">hc.practitioner</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create the practitioner list used for Sprint 1 scheduling.</p>
        </field>
    </record>
</odoo>
