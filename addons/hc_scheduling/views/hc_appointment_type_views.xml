<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_appointment_type_list" model="ir.ui.view">
        <field name="name">hc.appointment.type.list</field>
        <field name="model">hc.appointment.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="practice_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hc_appointment_type_form" model="ir.ui.view">
        <field name="name">hc.appointment.type.form</field>
        <field name="model">hc.appointment.type</field>
        <field name="arch" type="xml">
            <form string="Visit Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="practice_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hc_appointment_types" model="ir.actions.act_window">
        <field name="name">Visit Types</field>
        <field name="res_model">hc.appointment.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create the visit types used for Sprint 1 scheduling.</p>
        </field>
    </record>
</odoo>
