<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_hc_checkout_summary" model="ir.actions.report">
        <field name="name">Checkout Summary</field>
        <field name="model">hc.checkout.session</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">hc_checkout.report_hc_checkout_summary</field>
        <field name="report_file">hc_checkout.report_hc_checkout_summary</field>
        <field name="binding_model_id" ref="model_hc_checkout_session"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Checkout Summary - %s' % (object.name)</field>
    </record>

    <record id="action_report_hc_payment_due" model="ir.actions.report">
        <field name="name">Payment Due</field>
        <field name="model">hc.checkout.session</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">hc_checkout.report_hc_payment_due</field>
        <field name="report_file">hc_checkout.report_hc_payment_due</field>
        <field name="print_report_name">'Payment Due - %s' % (object.name)</field>
    </record>

    <record id="action_report_hc_patient_statement" model="ir.actions.report">
        <field name="name">Patient Statement</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">hc_checkout.report_hc_patient_statement</field>
        <field name="report_file">hc_checkout.report_hc_patient_statement</field>
        <field name="print_report_name">'Patient Statement - %s' % (object.name)</field>
    </record>

    <template id="report_hc_checkout_summary">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="session">
                <div class="page">
                    <h2>Checkout Summary</h2>
                    <p>
                        <strong>Practice:</strong>
                        <span t-esc="session.appointment_id.practice_id.display_name"/>
                    </p>
                    <p>
                        <strong>Checkout:</strong>
                        <span t-esc="session.name"/>
                    </p>
                    <p>
                        <strong>Patient:</strong>
                        <span t-esc="session.patient_id.display_name"/>
                    </p>
                    <p>
                        <strong>Appointment:</strong>
                        <span t-esc="session.appointment_id.display_name"/>
                    </p>
                    <p>
                        <strong>Appointment Start:</strong>
                        <span t-field="session.appointment_start"/>
                    </p>
                    <p t-if="session.practitioner_id">
                        <strong>Practitioner:</strong>
                        <span t-esc="session.practitioner_id.display_name"/>
                    </p>

                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="session.checkout_line_ids" t-as="line">
                                <td>
                                    <span t-esc="line.description"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'%.2f' % line.amount"/>
                                    <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <p>
                        <strong>Total:</strong>
                        <span t-esc="'%.2f' % session.amount_total"/>
                        <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                    </p>
                    <p>
                        <strong>Payment State:</strong>
                        <span t-esc="dict(session._fields['state'].selection).get(session.state)"/>
                    </p>
                    <p t-if="session.state == 'paid'">
                        <strong>Tender:</strong>
                        <span t-esc="dict(session._fields['tender_type'].selection).get(session.tender_type)"/>
                    </p>
                    <p t-if="session.state == 'paid' and session.paid_on">
                        <strong>Paid On:</strong>
                        <span t-field="session.paid_on"/>
                    </p>
                </div>
            </t>
        </t>
    </template>

    <template id="report_hc_payment_due">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="session">
                <div class="page">
                    <h2>Payment Due</h2>
                    <p>
                        <strong>Practice:</strong>
                        <span t-esc="session.appointment_id.practice_id.display_name"/>
                    </p>
                    <p>
                        <strong>Checkout:</strong>
                        <span t-esc="session.name"/>
                    </p>
                    <p>
                        <strong>Patient:</strong>
                        <span t-esc="session.patient_id.display_name"/>
                    </p>
                    <p>
                        <strong>Appointment:</strong>
                        <span t-esc="session.appointment_id.display_name"/>
                    </p>
                    <p>
                        <strong>Appointment Start:</strong>
                        <span t-field="session.appointment_start"/>
                    </p>
                    <p t-if="session.practitioner_id">
                        <strong>Practitioner:</strong>
                        <span t-esc="session.practitioner_id.display_name"/>
                    </p>

                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="session.checkout_line_ids" t-as="line">
                                <td>
                                    <span t-esc="line.description"/>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'%.2f' % line.amount"/>
                                    <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <p>
                        <strong>Total Due:</strong>
                        <span t-esc="'%.2f' % session.amount_total"/>
                        <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                    </p>
                    <p>
                        <strong>Payment State:</strong>
                        <span t-esc="dict(session._fields['state'].selection).get(session.state)"/>
                    </p>
                    <p t-if="session.payment_note">
                        <strong>Due Note:</strong>
                        <span t-esc="session.payment_note"/>
                    </p>
                </div>
            </t>
        </t>
    </template>

    <template id="report_hc_patient_statement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="patient">
                <t t-set="sessions" t-value="patient._get_payment_due_checkout_sessions()"/>
                <div class="page">
                    <h2>Patient Statement</h2>
                    <p t-if="patient._get_patient_statement_practice()">
                        <strong>Practice:</strong>
                        <span t-esc="patient._get_patient_statement_practice().display_name"/>
                    </p>
                    <p>
                        <strong>Patient:</strong>
                        <span t-esc="patient.display_name"/>
                    </p>

                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>Checkout</th>
                                <th>Appointment</th>
                                <th>Appointment Start</th>
                                <th class="text-end">Amount Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="sessions" t-as="session">
                                <tr>
                                    <td>
                                        <span t-esc="session.name"/>
                                    </td>
                                    <td>
                                        <span t-esc="session.appointment_id.display_name"/>
                                    </td>
                                    <td>
                                        <span t-field="session.appointment_start"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % session.amount_total"/>
                                        <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                                    </td>
                                </tr>
                                <tr t-if="session.checkout_line_ids or session.payment_note">
                                    <td colspan="4">
                                        <div t-if="session.checkout_line_ids">
                                            <strong>Lines:</strong>
                                            <ul>
                                                <li t-foreach="session.checkout_line_ids" t-as="line">
                                                    <span t-esc="line.description"/>
                                                    <span> - </span>
                                                    <span t-esc="'%.2f' % line.amount"/>
                                                    <span t-esc="session.currency_id.symbol or session.currency_id.name"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <p t-if="session.payment_note">
                                            <strong>Note:</strong>
                                            <span t-esc="session.payment_note"/>
                                        </p>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <p>
                        <strong>Total Due:</strong>
                        <span t-esc="'%.2f' % patient._get_payment_due_total()"/>
                        <span t-esc="sessions[:1].currency_id.symbol or sessions[:1].currency_id.name"/>
                    </p>
                </div>
            </t>
        </t>
    </template>
</odoo>
