<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_practice_list" model="ir.ui.view">
        <field name="name">hc.practice.list</field>
        <field name="model">hc.practice</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="timezone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hc_practice_form" model="ir.ui.view">
        <field name="name">hc.practice.form</field>
        <field name="model">hc.practice</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="timezone"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hc_practice" model="ir.actions.act_window">
        <field name="name">Practices</field>
        <field name="res_model">hc.practice</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create the clinic or practice records used in Sprint 1.</p>
        </field>
    </record>
</odoo>
