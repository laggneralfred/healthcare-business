<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_hc_practice" model="ir.ui.view">
        <field name="name">res.users.form.hc.practice</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tz']" position="after">
                <field name="practice_id" groups="hc_practice_core.hc_group_owner"/>
            </xpath>
        </field>
    </record>
</odoo>
