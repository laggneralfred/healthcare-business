<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_service_fee_list" model="ir.ui.view">
        <field name="name">hc.service.fee.list</field>
        <field name="model">hc.service.fee</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="practice_id"/>
                <field name="default_price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hc_service_fee_form" model="ir.ui.view">
        <field name="name">hc.service.fee.form</field>
        <field name="model">hc.service.fee</field>
        <field name="arch" type="xml">
            <form string="Service Fee">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="practice_id"/>
                        <field name="default_price"/>
                        <field name="currency_id"/>
                        <field name="active"/>
                        <field name="short_description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hc_service_fees" model="ir.actions.act_window">
        <field name="name">Service Fees</field>
        <field name="res_model">hc.service.fee</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Define a small practice-owned list of service fee defaults for checkout.</p>
        </field>
    </record>

    <record id="action_hc_service_fees_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="hc_pricing.view_hc_service_fee_list"/>
        <field name="act_window_id" ref="hc_pricing.action_hc_service_fees"/>
    </record>

    <record id="action_hc_service_fees_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hc_pricing.view_hc_service_fee_form"/>
        <field name="act_window_id" ref="hc_pricing.action_hc_service_fees"/>
    </record>
</odoo>
