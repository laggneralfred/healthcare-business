<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hc_appointment_form_consent" model="ir.ui.view">
        <field name="name">hc.appointment.form.consent</field>
        <field name="model">hc.appointment</field>
        <field name="inherit_id" ref="hc_scheduling.view_hc_appointment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group[1]" position="after">
                <group string="Consent">
                    <field name="consent_status" readonly="1"/>
                    <button
                        name="action_record_consent"
                        string="Record Consent"
                        type="object"
                        class="btn-secondary"
                        groups="hc_practice_core.hc_group_owner,hc_practice_core.hc_group_front_desk"
                    />
                    <button
                        name="action_share_consent_link"
                        string="Get Consent Link"
                        type="object"
                        class="btn-secondary"
                        groups="hc_practice_core.hc_group_owner,hc_practice_core.hc_group_front_desk"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
